---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Abdulhakim Aloraini">
  <main id="main" class="nf">
    <div class="wrap">
      <p class="nf__code">404</p>
      <h1 class="nf__title">Page not found</h1>
      <p class="nf__text">That page does not exist.</p>
      <a class="btn btn--solid" href="/">Back to home</a>
    </div>
  </main>
</BaseLayout>

<style>
  .nf { min-height: 70vh; display: flex; align-items: center; }
  .nf__code {
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }
  .nf__title { font-size: clamp(2.5rem, 8vw, 5rem); margin-bottom: 1rem; }
  .nf__text { color: var(--muted); margin-bottom: 2rem; }
</style>
