---
const links = [
  { label: 'Experience', href: '#experience' },
  { label: 'Work', href: '#work' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="nav">
  <div class="nav__inner wrap">
    <a class="nav__brand" href="#main">Abdulhakim Aloraini</a>
    <div class="nav__right">
      <nav class="nav__links" aria-label="Primary">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <button class="nav__theme" type="button" aria-label="Toggle dark mode" data-theme-toggle>
        <svg class="nav__icon nav__icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="nav__icon nav__icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector('[data-theme-toggle]');
  if (btn) {
    const root = document.documentElement;
    const systemDark = () => window.matchMedia('(prefers-color-scheme: dark)').matches;
    const effective = () => root.dataset.theme || (systemDark() ? 'dark' : 'light');
    const sync = () => btn.setAttribute('aria-pressed', String(effective() === 'dark'));
    sync();
    btn.addEventListener('click', () => {
      const next = effective() === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      sync();
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(150%) blur(10px);
    -webkit-backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
  }
  .nav__brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .nav__right {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 1.75rem);
  }
  .nav__links {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
  }
  .nav__links a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.18s ease;
  }
  .nav__links a:hover { color: var(--ink); }

  .nav__theme {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition: border-color 0.18s ease, color 0.18s ease;
  }
  .nav__theme:hover { border-color: var(--ink); color: var(--accent); }
  .nav__icon { width: 1.05rem; height: 1.05rem; }

  /* Icon reflects the effective theme (mirror of the token rules) */
  .nav__icon--sun { display: none; }
  .nav__icon--moon { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .nav__icon--sun { display: block; }
    :root:not([data-theme='light']) .nav__icon--moon { display: none; }
  }
  :root[data-theme='dark'] .nav__icon--sun { display: block; }
  :root[data-theme='dark'] .nav__icon--moon { display: none; }
  :root[data-theme='light'] .nav__icon--sun { display: none; }
  :root[data-theme='light'] .nav__icon--moon { display: block; }

  @media (max-width: 460px) {
    .nav__brand { font-size: 0.9rem; }
    .nav__links { gap: 1rem; }
    .nav__links a { font-size: 0.72rem; }
    .nav__right { gap: 0.85rem; }
  }
</style>
