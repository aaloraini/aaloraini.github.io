---
const quote =
  'In under two months he launched the app successfully, and consistently exceeded expectations.';
---

<section class="section recognition" id="recognition">
  <div class="wrap">
    <h2 class="eyebrow"><span>Recognition</span> <span class="bar" aria-hidden="true"></span></h2>

    <figure class="quote">
      <blockquote class="quote__text">&ldquo;{quote}&rdquo;</blockquote>
      <figcaption class="quote__by">
        <span class="quote__who">
          Appreciation letter, Four Hundred Entertainment <span class="quote__ar" dir="rtl">(صن وحكم)</span>
        </span>
        <span class="quote__meta">
          Two-month Product Owner consulting engagement, 2025 · translated from Arabic ·
          <a href="/appreciation-letter.pdf" target="_blank" rel="noopener noreferrer">view original ↗</a>
        </span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .quote { max-width: 62rem; margin: 0; }
  .quote__text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 3.6vw, 2.7rem);
    line-height: 1.22;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .quote__by {
    margin-top: 1.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .quote__who {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .quote__ar { font-weight: 700; }
  .quote__meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }
  .quote__meta a {
    color: var(--muted);
    border-bottom: 1px solid var(--line);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .quote__meta a:hover { color: var(--accent); border-color: var(--accent); }
</style>
