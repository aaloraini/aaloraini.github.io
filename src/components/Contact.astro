---
const links = [
  { label: 'Email', value: 'hkem.moh.ar@gmail.com', href: 'mailto:hkem.moh.ar@gmail.com' },
  { label: 'Phone', value: '+966 56 333 8070', href: 'tel:+966563338070' },
  { label: 'LinkedIn', value: '/in/abdulhakim-aloraini', href: 'https://www.linkedin.com/in/abdulhakim-aloraini/' },
  { label: 'GitHub', value: '@aaloraini', href: 'https://github.com/aaloraini' },
];

const year = new Date().getFullYear();
---

<section class="section contact" id="contact">
  <div class="wrap">
    <h2 class="eyebrow"><span class="num" aria-hidden="true">05</span> Contact <span class="bar" aria-hidden="true"></span></h2>

    <p class="contact__headline">Let's build<br />something.</p>
    <p class="contact__sub">
      Open to product, operations, and engineering work. The fastest way to reach me is email.
    </p>

    <ul class="contact__links">
      {links.map((l) => (
        <li>
          <a href={l.href} target={l.href.startsWith('mailto:') || l.href.startsWith('tel:') ? undefined : '_blank'} rel="noopener noreferrer">
            <span class="contact__label">{l.label}</span>
            <span class="contact__value">{l.value} <span aria-hidden="true">↗</span></span>
          </a>
        </li>
      ))}
    </ul>

    <footer class="foot">
      <span>© {year} Abdulhakim Aloraini</span>
      <span>Built with Astro · Riyadh / Kuala Lumpur</span>
    </footer>
  </div>
</section>

<style>
  .contact__headline {
    font-size: clamp(3rem, 11vw, 8rem);
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .contact__sub {
    color: var(--muted);
    max-width: 48ch;
    margin-top: 1.5rem;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
  }
  .contact__links {
    list-style: none;
    margin-top: clamp(2.5rem, 6vw, 4rem);
    border-top: 1.5px solid var(--line-strong);
  }
  .contact__links li { border-bottom: 1px solid var(--line); }
  .contact__links a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1rem, 3vw, 1.5rem);
    transition: padding-left 0.2s ease, color 0.2s ease;
  }
  .contact__links a:hover { padding-left: 1rem; color: var(--accent); }
  .contact__label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .contact__links a:hover .contact__label { color: var(--accent); }
  .contact__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 3.5vw, 2rem);
    letter-spacing: -0.02em;
    text-align: right;
  }

  .foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    justify-content: space-between;
    margin-top: clamp(3rem, 7vw, 5rem);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--faint);
  }
</style>
