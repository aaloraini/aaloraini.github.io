---
import { featured, more } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section class="section work" id="work">
  <div class="wrap">
    <h2 class="eyebrow"><span class="num" aria-hidden="true">01</span> Selected work <span class="bar" aria-hidden="true"></span></h2>

    <div class="stack">
      {featured.map((project, i) => (
        <div class="stack__item" style={`--i:${i}`}>
          <ProjectCard project={project} index={i} />
        </div>
      ))}
    </div>

    <h3 class="more__heading">Also built</h3>
    <ul class="more">
      {more.map((p) => (
        <li class="more__item">
          <div class="more__top">
            <h4 class="more__name">{p.name}</h4>
            {p.status && <span class="more__status">{p.status}</span>}
          </div>
          <p class="more__tagline">{p.tagline}</p>
          <div class="more__foot">
            <ul class="more__tags">
              {p.tags.map((t) => <li class="tag">{t}</li>)}
            </ul>
            {p.links && p.links.length > 0 && (
              <div class="more__links">
                {p.links.map((l) => (
                  <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Sticky card-stack: each card pins, the next slides up and stacks over it.
     Pure native vertical scroll; degrades to a plain list on small screens. */
  .stack {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 6vw, 4.5rem);
  }
  .stack__item {
    position: sticky;
    top: calc(4.5rem + var(--i) * 0.9rem);
  }
  @media (max-width: 760px) {
    .stack__item { position: static; }
    .stack { gap: 1.5rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .stack__item { position: static; }
  }

  .more__heading {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: clamp(3rem, 7vw, 5rem);
    margin-bottom: 1.5rem;
  }
  .more {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .more__item {
    background: var(--bg);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .more__top { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; }
  .more__name { font-size: 1.3rem; letter-spacing: -0.01em; }
  .more__status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    white-space: nowrap;
  }
  .more__tagline { color: var(--muted); font-size: 0.95rem; flex: 1; }
  .more__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }
  .more__tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .more__links { display: flex; gap: 0.9rem; }
  .more__links a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    border-bottom: 2px solid var(--ink);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .more__links a:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 680px) {
    .more { grid-template-columns: 1fr; }
  }
</style>
