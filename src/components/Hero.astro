---
const stats = [
  { k: '3,000+', v: 'emergency vehicles equipped nationwide' },
  { k: '1.8M+', v: 'people served during Hajj 1445' },
  { k: '3', v: 'apps shipped on the App Store' },
];
---

<header class="hero">
  <div class="wrap">
    <p class="kicker">Product · Operations · Engineering · Open to the Gulf &amp; remote</p>
    <h1 class="name">Abdulhakim<br />Aloraini</h1>

    <div class="lede-row">
      <p class="tagline"><em>I lead products,</em> and build them.</p>
      <p class="lede">
        I run delivery end to end and build my own apps and hardware, so I understand the
        technical detail deeply enough to make the right calls and communicate clearly with
        both engineers and stakeholders.
      </p>
      <p class="hero__about">
        Based in Riyadh, finishing a B.Eng. in Electrical &amp; Electronics Engineering, and
        targeting technical product management roles across Saudi Arabia, the Gulf, and remote.
      </p>
    </div>

    <div class="cta">
      <a class="btn btn--solid" href="#work">View work</a>
      <a class="btn btn--ghost" href="#contact">Get in touch</a>
    </div>

    <dl class="stats">
      {stats.map((s) => (
        <div class="stat">
          <dt>{s.k}</dt>
          <dd>{s.v}</dd>
        </div>
      ))}
    </dl>
  </div>
</header>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4rem);
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .name {
    font-size: clamp(3.25rem, 13vw, 10.5rem);
    letter-spacing: -0.035em;
    text-transform: uppercase;
  }
  .lede-row {
    display: grid;
    gap: 1.25rem;
    margin-top: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 64ch;
  }
  .tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    letter-spacing: -0.02em;
  }
  .tagline em { color: var(--accent); font-style: normal; }
  .lede {
    font-size: clamp(1.05rem, 1.4vw, 1.3rem);
    max-width: 56ch;
  }
  .hero__about {
    font-size: 0.98rem;
    color: var(--muted);
    max-width: 56ch;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: clamp(3rem, 7vw, 5rem);
    border-top: 1.5px solid var(--line-strong);
    padding-top: 1.75rem;
  }
  .stat dt {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.03em;
    color: var(--accent);
  }
  .stat dd {
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 0.35rem;
    max-width: 24ch;
  }
  @media (max-width: 640px) {
    .stats { grid-template-columns: 1fr; gap: 1.1rem; }
    .stat { display: flex; align-items: baseline; gap: 1rem; }
    .stat dt { font-size: 2rem; }
    .stat dd { margin-top: 0; }
  }
</style>
