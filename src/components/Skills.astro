---
const lead = {
  label: 'Product & Growth',
  items: [
    'Product ownership',
    'Product strategy & roadmap',
    'Requirements & specs',
    'MVP & launch',
    'Prioritization',
    'Analytics & retention',
    'Monetization & pricing',
  ],
};

const groups = [
  {
    label: 'Delivery & Operations',
    items: [
      'Agile / Scrum',
      'Project & operations management',
      'Large-scale rollouts',
      'Risk management',
      'Stakeholder & vendor management',
      'Cross-functional & team leadership',
    ],
  },
  {
    label: 'Software & Tools',
    items: [
      'Swift / SwiftUI',
      'Python',
      'C++',
      'Xcode',
      'Figma',
      'KiCad',
      'AutoCAD',
      'Git & GitHub',
      'Firebase',
      'Excel',
      'MS Project',
    ],
  },
  {
    label: 'Electronics & Embedded',
    items: [
      'PCB design',
      'SMT',
      'MSP430',
      'Embedded (ESP32, Arduino, RPi)',
      'AVL / IoT',
      'Troubleshooting & repair',
    ],
  },
];
---

<section class="section" id="skills">
  <div class="wrap">
    <h2 class="eyebrow"><span class="num" aria-hidden="true">03</span> Skills <span class="bar" aria-hidden="true"></span></h2>

    <div class="skills">
      <div class="sgroup sgroup--lead">
        <h3 class="sgroup__label">{lead.label}</h3>
        <ul class="pills">
          {lead.items.map((i) => <li class="pill">{i}</li>)}
        </ul>
      </div>

      {groups.map((g) => (
        <div class="sgroup">
          <h3 class="sgroup__label">{g.label}</h3>
          <ul class="pills">
            {g.items.map((i) => <li class="pill">{i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: clamp(2rem, 5vw, 3.25rem) clamp(2rem, 5vw, 4rem);
  }
  .sgroup--lead { grid-column: 1 / -1; }
  .sgroup__label {
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    padding-bottom: 0.9rem;
    border-bottom: 1.5px solid var(--line-strong);
    margin-bottom: 1.25rem;
  }
  .pills {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pill {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 0.45rem 0.9rem;
    transition: border-color 0.18s ease;
  }
  .pill:hover { border-color: var(--ink); }
</style>
