---
const groups = [
  {
    label: 'Product & Operations',
    items: ['Planning & execution', 'Risk management', 'KPIs & reporting', 'Stakeholder alignment', 'Agile / Scrum', 'Vendor & field coordination'],
  },
  {
    label: 'Software',
    items: ['Swift / SwiftUI', 'Python', 'C++', 'Git & GitHub', 'WidgetKit', 'CloudKit'],
  },
  {
    label: 'Electronics & Embedded',
    items: ['PCB design (KiCad)', 'SMT manufacture', 'Arduino · ESP32 · Raspberry Pi', 'AVL / IoT / Teltonika', 'Troubleshooting & repair'],
  },
  {
    label: 'Tools',
    items: ['AutoCAD', 'Excel', 'Documentation', 'End-user training'],
  },
];
---

<section class="section" id="skills">
  <div class="wrap">
    <p class="eyebrow"><span class="num">03</span> Skills <span class="bar"></span></p>

    <div class="grid">
      {groups.map((g) => (
        <div class="group">
          <h3 class="group__label">{g.label}</h3>
          <ul class="group__items">
            {g.items.map((it) => <li>{it}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 5vw, 3.5rem) clamp(2rem, 6vw, 5rem);
  }
  .group__label {
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    padding-bottom: 0.9rem;
    border-bottom: 1.5px solid var(--line-strong);
    margin-bottom: 1.1rem;
  }
  .group__items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .group__items li {
    position: relative;
    padding-left: 1.3rem;
    color: var(--muted);
  }
  .group__items li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 0.5rem;
    height: 1.5px;
    background: var(--accent);
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
